# ─────────────────────────────────────────────────────────────
# Production stack template.
#
# Copy to .env.prod, fill in real secrets, and bring up via
# `docker-compose -f docker-compose.prod.yml up -d`.
# .env.prod is gitignored; this template is committed.
# ─────────────────────────────────────────────────────────────

APP_ENV=production
APP_PORT=8000
LOG_LEVEL=INFO                # WARNING in prod is also fine

# ── Database (managed Postgres in prod) ──────────────────
# Prefer a managed DB (RDS / Cloud SQL / Neon). DATABASE_URL takes
# precedence over the POSTGRES_* fields when set.
POSTGRES_USER=rit_prod_user
POSTGRES_PASSWORD=
POSTGRES_DB=resume_intelligence
POSTGRES_HOST=
POSTGRES_PORT=5432
DATABASE_URL=

# ── CORS — restrict to the deployed dashboard origin ─────
# DO NOT include localhost in prod. Add the extension via
# ALLOWED_ORIGIN_REGEX only.
ALLOWED_ORIGINS=["https://tracker.your-domain.com"]
ALLOWED_ORIGIN_REGEX=chrome-extension://.*

# ── LLM ──────────────────────────────────────────────────
# Cloud provider (OpenAI / Groq / etc.). Keep the key in your secret
# manager — never check into git.
LLM_PROVIDER=groq
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=
LLM_MODEL=llama-3.3-70b-versatile
LLM_TIMEOUT_SEC=120

ENABLE_EMAIL_WATCHER=false
DEFAULT_OWNER_ID=00000000-0000-0000-0000-000000000001
GEMINI_API_KEY=
