# ── Application ──────────────────────────────────────────
APP_ENV=development           # development | production
APP_PORT=8000
LOG_LEVEL=INFO                # DEBUG | INFO | WARNING | ERROR

# ── Database ─────────────────────────────────────────────
POSTGRES_USER=rit_user
POSTGRES_PASSWORD=rit_password
POSTGRES_DB=resume_intelligence
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Constructed from above — used by SQLAlchemy
DATABASE_URL=postgresql+asyncpg://rit_user:rit_password@localhost:5432/resume_intelligence

# ── CORS ─────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ── Future: LLM APIs (placeholder) ───────────────────────
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
