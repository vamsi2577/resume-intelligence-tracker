# ─────────────────────────────────────────────────────────────
# RIT environment template
#
# Copy this file once per stack:
#   cp .env.example .env.dev      # local development
#   cp .env.example .env.e2e      # automated e2e tests
#   cp .env.example .env.prod     # production deploy
#
# Each docker-compose file loads its matching env_file by name.
# Real values are gitignored — never commit secrets.
# ─────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────
# Must match one of: development | e2e | staging | production | test
# Set explicitly per stack — pydantic validates the value at boot.
APP_ENV=development
APP_PORT=8000
LOG_LEVEL=INFO                # DEBUG | INFO | WARNING | ERROR

# ── Database ─────────────────────────────────────────────
POSTGRES_USER=rit_user
POSTGRES_PASSWORD=change-me
POSTGRES_DB=resume_intelligence
POSTGRES_HOST=localhost       # use `postgres` inside docker compose
POSTGRES_PORT=5432

# Assembled automatically from the POSTGRES_* values above when blank.
# Override only if you need a non-standard URL (e.g. cloud DB with SSL).
DATABASE_URL=

# ── CORS ─────────────────────────────────────────────────
# JSON-encoded list. The Chrome extension is accepted via
# ALLOWED_ORIGIN_REGEX below, so it doesn't need to be listed here.
ALLOWED_ORIGINS=["http://localhost:3000", "http://localhost:8000", "http://localhost"]
ALLOWED_ORIGIN_REGEX=chrome-extension://.*

# ── LLM (OpenAI-compatible chat completions) ─────────────
# Works with OpenAI / Groq / Together / Anthropic-via-proxy / Ollama / vLLM / etc.
LLM_PROVIDER=groq
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=                  # leave blank to disable JD → résumé generation
LLM_MODEL=llama-3.3-70b-versatile
LLM_TIMEOUT_SEC=120

# ── Feature gates ────────────────────────────────────────
# n8n / Gmail email-watcher path is deprecated.
# Flip to true (and bring up `docker-compose --profile email up`) to re-enable.
ENABLE_EMAIL_WATCHER=false

# Forward-compat single-tenant owner UUID. Phase 5 (multi-tenant SaaS)
# replaces this with real auth and per-user owner_ids.
DEFAULT_OWNER_ID=00000000-0000-0000-0000-000000000001

# ── Legacy / unused (kept for back-compat) ───────────────
GEMINI_API_KEY=
